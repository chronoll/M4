graph LR
    C["[1] Controller<br/>リクエスト受信"]
    CG["[2] CommandGateway<br/>Command 送信"]
    A["[3] OrderAggregate<br/>@CommandHandler"]
    E["[4] Event 発行<br/>@EventSourcingHandler<br/>状態更新"]
    P["Projection<br/>@EventHandler<br/>読み取りデータ更新"]
